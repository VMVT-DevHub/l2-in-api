{
  "type": "Categorization",
  "options": {
    "display": "form",
    "labels": {
      "pareiskejas": "Pareiškėjas",
      "subjektas": "Subjektas",
      "dokumentai": "Dokumentai",
      "sutikimai": "Sutikimai"
    }
  },
  "elements": [
    {
      "type": "Category",
      "label": "Pareiškėjas",
      "elements": [
        {
          "$ref": "forms/global/uiDefs.json#/definitions/atsakingas-asmuo-evv"
        },
        {
          "type": "Group",
          "label": "Ūkio subjekto duomenys",
          "elements": [
            {
              "type": "HorizontalLayout",
              "options": {
                "columns": 3
              },
              "elements": [
                {
                  "type": "Control",
                  "scope": "#/properties/pareiskejas/properties/ja-duomenys/properties/ja-pavadinimas",
                  "options": {
                    "display": "authField",
                    "key": "companyName"
                  }
                },
                {
                  "type": "Control",
                  "scope": "#/properties/pareiskejas/properties/ja-duomenys/properties/ja-teisine-forma",
                  "options": {
                    "display": "authField",
                    "key": "form"
                  }
                },
                
                {
                  "type": "Control",
                  "scope": "#/properties/pareiskejas/properties/ja-duomenys/properties/ja-moketojo-kodas",
                  "options": {
                    "display": "authField",
                    "key": "activeOrgCode"
                  }
                }
              ]
            },
            {
              "type": "Control",
              "scope": "#/properties/pareiskejas/properties/ja-duomenys/properties/adresas/properties/ja-gyv",
                "options": {
                "display": "addressSelect"
              },
              "rule": {
                "effect": "DISABLE",
                "condition": {
                  "scope": "#/properties/pareiskejas/properties/atsakingas-asmuo/properties/aob",
                  "schema": {"type": "string"},
                  "failWhenUndefined": true
                }
              }
            }
          ],
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/pareiskejas/properties/atsakingas-asmuo/properties/ja",
              "schema": {"type": "string"},
              "failWhenUndefined": true
            }
          }
        },
        {
          "type": "Group",
          "label": "Ūkio subjekto duomenys",
          "elements": [
            {
              "type": "HorizontalLayout",
              "options": {
                "columns": 2
              },
              "elements": [
                {
                  "type": "Control",
                  "scope": "#/properties/pareiskejas/properties/fa-duomenys/properties/vardas",
                  "options": {
                    "display": "authField",
                    "key": "firstName"
                  }
                },
                {
                  "type": "Control",
                  "scope": "#/properties/pareiskejas/properties/fa-duomenys/properties/pavarde",
                  "options": {
                    "display": "authField",
                    "key": "lastName"
                  }
                },
                {
                  "type": "Control",
                  "scope": "#/properties/pareiskejas/properties/fa-duomenys/properties/fa-moketojo-kodas",
                  "options": {
                    "display": "authField",
                    "key": "ak"
                  }
                }
              ]
            }
          ],
          "rule": {
            "effect": "HIDE",
            "condition": {
              "scope": "#/properties/pareiskejas/properties/atsakingas-asmuo/properties/ja",
              "schema": {"type": "string"},
              "failWhenUndefined": true
            }
          }
        }
      ]
    },
    {
      "type": "Category",
      "label": "Veiklavietė",
      "elements": [
        {
          "type": "Group",
          "label": "Duomenys apie ūkio subjekto veiklavietę",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/veiklaviete/properties/registracijos-nr"
            }
          ]
        },
        {
          "type": "Group",
          "label": "Ūkio subjekto veiklavietės adresas",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/veiklaviete/properties/adresas/properties/ja-gyv",
              "options": {
                "display": "addressSelect"
              }
            },
            {
              "type": "Control",
              "scope": "#/properties/veiklaviete/properties/adresas/properties/ar-bus-koordinates"
            }
          ]
        },
         {
          "type": "Group",
          "label": "WGS koordinatės",
          "elements": [
            {
              "type": "HorizontalLayout",
              "elements": [
                {
                  "type": "Control",
                  "scope": "#/properties/veiklaviete/properties/koordinates/properties/platuma",
                  "options": {
                    "placeholder": "Pvz.: 54.7090"
                  }
                },
                {
                  "type": "Control",
                  "scope": "#/properties/veiklaviete/properties/koordinates/properties/ilguma",
                  "options": {
                    "placeholder": "Pvz.: 25.2474"
                  }
                }
              ]
            }
          ],
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/veiklaviete/properties/adresas/properties/ar-bus-koordinates",
              "schema": { "const": true },
              "failWhenUndefined": true
            }
          }
        },
        {
          "type": "Group",
          "label": "Prašau",
          "elements": [
            {
              "type": "Control",
              "label": "Pakeisti šiuos valstybinės veterinarinės kontrolės subjekto ir / arba registruotos / patvirtintos veiklos duomenis:",
              "scope": "#/properties/pakeitimai/properties/title",
              "options": {
                "display": "PlainText"
              }
            },
            {
              "type": "Control",
              "scope": "#/properties/pakeitimai/properties/kontakt",
               "options": {
                "margin": "16px"
              }
            },
            {
              "type": "Control",
              "scope": "#/properties/pakeitimai/properties/veikla",
               "options": {
                "margin": "16px"
              }
             
            },
            {
              "type": "Control",
              "scope": "#/properties/pakeitimai/properties/irenginiai", 
              "options": {
                "margin": "16px"
              }
             
            },
            {
              "type": "Control",
              "scope": "#/properties/pakeitimai/properties/procesas",
               "options": {
                "margin": "16px"
              }
             
            },
            {
              "type": "Control",
              "scope": "#/properties/pakeitimai/properties/assort",
               "options": {
                "margin": "16px"
              }
             
            },
            {
              "type": "Control",
              "scope": "#/properties/pakeitimai/properties/kita",
               "options": {
                "margin": "16px"
              }
            },
             {
              "type": "Control",
              "scope": "#/properties/pakeitimai/properties/kita-info",
              "options": {
                "margin": "32px"
              },
               "rule": {
                "effect": "SHOW",
                "condition": {
                  "scope": "#/properties/pakeitimai/properties/kita",
                  "schema": {
                    "const": true
                  }
                }
              }
            }
          ]
        }
         
      ]
    },
    {
      "type": "Category",
      "label": "Dokumentai",
      "elements": [
      {
          "type": "Group",
          "label": "Pridedami dokumentai",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/dokumentai/properties/pridedami-dokumentai",
              "label": "",
              "options": {
                "display": "upload",
                "multi": true, 
                "certType":"vet",
                "hasInfoField": true
              }
            }
          ]
        },
        {
          "type": "Group",
          "label": "Papildoma informacija",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/dokumentai/properties/papildoma-info",
              "options": {
                "display": "textarea"
              }
            }
          ]
        }
      ]
    },
     {
      "type": "Category",
      "label": "Sutikimai",
      "elements": [
        {
          "type": "Group",
          "label": "Sutikimas",
          "description": "Sutikimas dėl duomenų pateikimo",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/sutikimai/properties/informuotas"
            },
            {
              "type": "Control",
              "scope": "#/properties/sutikimai/properties/gauti-info-pastu"
            }
          ]
        },
        {
          "type": "Group",
          "label": "",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/sutikimai/properties/pastas",
               "options": {
                "clearOnCopy": true,
                "display": "authField",
                "key": "email"
              }
            }
          ],
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/sutikimai/properties/gauti-info-pastu",
              "schema": { "const": true }
            }
          }
        },
        {
          "type": "Group",
          "label": "Atsakymas",
          "description": "Pažymėkite būdą, kuriuo pageidaujate gauti atsakymą",
          "elements": [
            {
              "type": "Control",
              "scope": "#/properties/sutikimai/properties/ats-gavimas",
              "options": {
                "display": "radio"
              }
            }
          ]
        }
      ]
    }
  ]
}

{
  "type": "object",
  "title": "Prašymas dėl valstybinės veterinarinės kontrolės subjekto duomenų keitimo",
  "additionalProperties": false,
  "properties": {
    "pareiskejas": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "atsakingas-asmuo": {
          "$ref": "forms/global/defs.json#/definitions/atsakingas-asmuo-evv"
        },
        "ja-duomenys": {
          "type": "object",
          "additionalProperties": true,
          "default": {},
          "properties": {
            "ja-pavadinimas": {
              "type": "string",
              "title": "Juridinio asmens pavadinimas",
              "readOnly": true
            },
            "ja-teisine-forma": {
              "type": "string",
              "title": "Juridinio asmens teisinė foma",
              "readOnly": true
            },
            "adresas": {
              "type": "object",
              "properties": {
                "ja-gyv": {
                "type": "object",
                "properties": {
                  "gyvId": { "type": "number" },
                  "gyvName": { "type": "string" },
                  "adrId": { "type": "number" },
                  "adrName": { "type": "string" }
                  }
                }
              }
            },
            "ja-moketojo-kodas": {
              "type": "string",
              "title": "Mokesčių mokėtojo identifikacinis kodas",
              "pattern": "^\\d{9}$",
              "errorMessage": {
                "pattern": "Mokesčių mokėtojo identifikacinis kodas turi būti galiojantis"
              }
            }
          }
        },
        "fa-duomenys": {
          "type": "object",
          "additionalProperties": false,
          "default": {},
          "properties": {
            "vardas": {
              "type": "string",
              "title": "Vardas",
              "readOnly": true
            },
            "pavarde": {
              "type": "string",
              "title": "Pavardė",
              "readOnly": true
            },
            "fa-moketojo-kodas": {
              "type": "string",
              "title": "Mokesčių mokėtojo identifikacinis kodas",
              "pattern": "^[0-9]{11}$",
              "errorMessage": {
                "pattern": "Mokesčių mokėtojo identifikacinis kodas turi būti galiojantis"
              }
            }
          }
        }
      },
      "required": ["atsakingas-asmuo"],
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": {
              "atsakingas-asmuo": {
                "type": "object",
                "properties": {
                  "ja": { "minLength": 1, "type": "string" }
                },
                "required": ["ja"]
              }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "ja-duomenys": {
                "type": "object",
                "required": ["ja-pavadinimas", "ja-teisine-forma", "ja-moketojo-kodas"],
                "errorMessage": {
                  "required": {
                    "ja-pavadinimas": "Juridinio asmens pavadinimas yra privalomas.",
                    "ja-teisine-forma": "Juridinio asmens teisinė foma yra privaloma.",
                    "ja-gyvenviete": "Juridinio asmens gyvenvietė yra privaloma.",
                    "ja-adresas": "Juridinio asmens adresas yra privalomas.",
                    "ja-moketojo-kodas": "Juridinio asmens moketojo kodas yra privalomas."
                  }
                }
              }
            }
          },
          "else": {
            "type": "object",
            "properties": {
              "fa-duomenys": {
                "type": "object",
                "required": ["vardas", "pavarde", "fa-moketojo-kodas"],
                "errorMessage": {
                  "required": {
                    "vardas": "Fizinio asmens vardas yra privalomas.",
                    "pavarde": "Fizinio asmens pavardė yra privaloma.",
                    "fa-moketojo-kodas": "Fizinio asmens mokėtojo kodas yra privalomas."
                  }
                }
              }
            }
          }
        }
      ]
    },
    "veiklaviete": {
      "type": "object",
      "additionalProperties": false,
      "default": {},
      "properties": {
        "registracijos-nr": {
          "type": "string",
          "title": "Registravimo / patvirtinimo Nr."
        },
        "adresas": {
          "type": "object",
          "additionalProperties": false,
          "default": {},
          "properties": {
            "ja-gyv": {
              "type": "object",
              "x-edit": true,
              "properties": {
                "gyvId": { "type": "number" },
                "gyvName": { "type": "string" },
                "adrId": { "type": "number" },
                "adrName": { "type": "string" }
              }
              
            },
            "ar-bus-koordinates": {
              "type": "boolean",
              "title": "Adresas buvo nurodomas WGS koordinatėmis",
              "description": "Žymima tuo atveju, kai arti veiklavietės nebuvo jokio pastato",
              "default": false
            }
          }
        },
         "koordinates": {
          "type": "object",
          "default": {},
          "properties": {
            "platuma": {
              "type": "string",
              "title": "Platuma *",
              "x-isCoordX": true,
              "pattern": "^(5[3-6]\\.\\d{4,})$",
              "errorMessage": {
                "pattern": "Platumos  formatas turi būti galiojantis",
                "minLength": "Koordinačių platuma privaloma"
              }
            },
            "ilguma": {
              "type": "string",
              "title": "Ilguma *",
              "x-isCoordY": true,
              "pattern": "^(2[0-6]\\.\\d{4,})$",
              "errorMessage": {
                "pattern": "Ilgumos formatas turi būti galiojantis",
                "minLength": "Koordinačių Ilguma privaloma"
              }
            }
          }
        },
        "pakeitimas": {
          "type": "string",
          "enum": [
            "Pakeisti šiuos administracinius registruoto / patvirtinto valstybinės veterinarinės kontrolės subjekto duomenis",
            "Pakeisti šiuos registruotos / patvirtintos veiklos duomenis"
          ]
        }
      }
    },
    "pakeitimai": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "kontakt": {
          "type": "boolean",
          "title": "keičiami kontaktiniai duomenys"
        },
        "veikla": {
          "type": "boolean",
          "title": "plečiama patvirtinta / registruota veikla toje pačioje veiklavietėje įrengiant naujas patalpas"
        },
        "irenginiai": {
          "type": "boolean",
          "title": "keičiami įrenginiai"
        },
        "procesas": {
          "type": "boolean",
          "title": "keičiamas technologinis procesas"
        },
        "assort": {
          "type": "boolean",
          "title": "keičiamas tvarkomų produktų asortimentas"
        },
        "kita": {
          "type": "boolean",
          "title": "kita (nurodyti)"
        },
        "kita-info": {
          "type": "string",
          "title": ""
        }
      }
    },
    "dokumentai": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pridedami-dokumentai": {
          "type": "array",
          "items": {
            "$ref": "forms/global/defs.json#/definitions/dokumentas"
          }
        },
        "papildoma-info": {
          "type": "string",
          "title": ""
        }
      }
    },
    "sutikimai": {
      "type": "object",
      "default": {},
      "properties": {
        "informuotas": {
          "type": "boolean",
          "title": "Esu informuotas (-a), kad mano asmens duomenys (vardas, pavardė ir gyvenamosios vietos adresas ir koordinatės, kai jis sutampa su veiklavietės adresu),  yra tvarkomi šiais tikslais: asmens, teikiančio šį prašymą, tapatybės nustatymui, patvirtinimo ar registravimo suteikimui, valstybinei veterinarinei kontrolei ir jos planavimui, viešinimui Licencijų informacinėje sistemoje,   Europos Komisijos ir VMVT svetainėje."
        },
        "gauti-info-pastu": {
          "type": "boolean",
          "title": "Sutinku gauti informaciją apie reikalavimų pakeitimus el.  paštu:"
        },
        "pastas": {
          "type": "string",
          "title": "Įveskite el. paštą"
        },
        "ats-gavimas": {
          "type": "string",
          "enum": [
            "Nacionalinę elektroninių siuntų pristatymo naudojant pašto tinklą informacinę sistemą",
            "El. paštu",
            "Paštu",
            "Kreipiantis asmeniškai arba per atstovą"
          ]
        }
      },
      "required": ["informuotas", "ats-gavimas"],
      "errorMessage": {
        "required": {
          "informuotas": "Sutikimas yra privalomas.",
          "ats-gavimas": "Atsakymo gavimo būdas yra privalomas."
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "veiklaviete": {
            "properties": {
              "adresas": {
                "properties": {
                  "ar-bus-koordinates": {
                    "const": false
                  }
                },
                "required": ["ar-bus-koordinates"]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "veiklaviete": {
            "properties": {
              "adresas": {
                "required": ["ja-gyv"],
                "properties": {
                  "ja-gyv": {
                    "required": ["gyvId", "adrId"],
                    "errorMessage": {
                      "required": {
                        "gyvId": "Adresas yra privalomas.",
                        "adrId": "Tikslus adresas yra privalomas."
                      }
                    }
                  }
                },
                "errorMessage": {
                  "required": {
                    "ja-gyv": "Adresas yra privalomas."
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "veiklaviete": {
            "properties": {
              "adresas": {
                "properties": {
                  "ar-bus-koordinates": {
                    "const": true
                  }
                },
                "required": ["ar-bus-koordinates"]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "veiklaviete": {
            "required": ["koordinates"],
            "properties": {
              "koordinates": {
                "required": ["platuma", "ilguma"],
                "errorMessage": {
                  "required": {
                    "platuma": "Koordinatės: Platuma yra privaloma.",
                    "ilguma": "Koordinatės: Ilguma yra privaloma."
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  
  "required": ["pareiskejas", "veiklaviete"],
  "errorMessage": {
    "required": {
      "pareiskejas": "Pareiškėjo informacija yra privaloma.",
      "veiklaviete": "Veiklavietės informacija yra privaloma."
    }
  }
}
